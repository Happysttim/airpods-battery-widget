{
  "name": "apps",
  "version": "1.0.0",
  "main": "./out/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:mac": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "airpods-bluetooth": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^0.6.5",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "40.8.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.8",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "build": {
    "appId": "com.happysttim.airpodswidget",
    "productName": "AirPods Widget",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "assets/**",
      "out/**",
      "package.json",
      "!src/**",
      "!node_modules/.cache/**"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "native/Release/airpods-bluetooth.node",
        "to": "native/airpods-bluetooth.node"
      },
      {
        "from": "resources/config.json",
        "to": "defaults/config.json"
      }
    ],
    "asar": true,
    "compression": "normal",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/airpods.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/airpods.ico",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "notarize": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/airpods.ico",
      "category": "Utility"
    }
  }
}
